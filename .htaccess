DirectoryIndex index.php index.html
Options -Indexes

<IfModule mod_authz_core.c>
  Require all granted
</IfModule>

<FilesMatch "(^\.|~$|\.(bak|old|orig|tmp|swp|swo|log|zip|tar|tgz|gz|patch|b64|ini|cfg|yml|yaml|csv|sqlite|db|md|txt|sh)$)">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

<FilesMatch "^(VERSION|tree\.txt|config\.ini|subscriber_ids\.csv|ABInfo_.*\.json)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule (^|/)(\.git|\.github|docs|systemd|tools|templates|includes|api/runtime|data/cache|data/private)(/|$) - [F,L]
</IfModule>
